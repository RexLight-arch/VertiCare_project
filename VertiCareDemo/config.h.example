static const uint8_t RFID_SCK_PIN = 19;
static const uint8_t RFID_MOSI_PIN = 20;
static const uint8_t RFID_MISO_PIN = 21;

// Module active levels. Change these if your module reports the opposite logic.
static const uint8_t RAIN_DIGITAL_ACTIVE_LEVEL = LOW;
static const uint8_t VIBRATION_ACTIVE_LEVEL = LOW;
static const uint8_t FLAME_ACTIVE_LEVEL = LOW;
static const uint8_t TILT_ACTIVE_LEVEL = LOW;
static const uint8_t TOUCH_ACTIVE_LEVEL = HIGH;
static const bool RAIN_DIGITAL_USE_PULLUP = true;
static const bool VIBRATION_USE_PULLUP = true;
static const bool FLAME_USE_PULLUP = true;
static const bool TILT_USE_PULLUP = true;
static const bool TOUCH_USE_PULLDOWN = false;

