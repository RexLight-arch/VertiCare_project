static const uint8_t SAFETY_ACTIVE_CONFIRM_SAMPLES = 1;
static const uint8_t SAFETY_CLEAR_CONFIRM_SAMPLES = 2;
// Rain detection calibrates its dry baseline after startup.
// With RAIN_ANALOG_WET_WHEN_LOW=true, rain is confirmed only after the ADC
// drops far enough below that baseline.
static const uint8_t RAIN_BASELINE_CALIBRATION_SAMPLES = 5;
static const int RAIN_WET_DROP_FROM_BASELINE = 250;
static const int RAIN_DRY_DROP_FROM_BASELINE = 100;
static const uint8_t RAIN_ADC_SAMPLE_COUNT = 9;
static const uint8_t RAIN_STATE_CONFIRM_SAMPLES = 4;
static const bool RAIN_USE_ANALOG = true;
static const bool RAIN_USE_DIGITAL = false;
static const bool RAIN_ANALOG_WET_WHEN_LOW = true;

