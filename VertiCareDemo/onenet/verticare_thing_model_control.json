{
  "profile": {
    "productName": "VertiCare",
    "category": "vertical_greening_manager",
    "description": "VertiCare vertical greening manager demo thing model for ESP32-C6, DHT11, photoresistor, rain sensor, SW-420 vibration sensor, and SG90 servo irrigation."
  },
  "properties": [
    {
      "identifier": "temperature",
      "functionType": "u",
      "name": "空气温度",
      "dataType": {
        "type": "float",
        "specs": {
          "min": -20,
          "max": 80,
          "step": 0.1
        }
      },
      "accessMode": "r",
      "description": "DHT11 measured ambient air temperature.",
      "unit": "°C"
    },
    {
      "identifier": "airHumidity",
      "functionType": "u",
      "name": "空气湿度",
      "dataType": {
        "type": "float",
        "specs": {
          "min": 0,
          "max": 100,
          "step": 0.1
        }
      },
      "accessMode": "r",
      "description": "DHT11 measured ambient air humidity, used by the demo as the irrigation control input.",
      "unit": "%"
    },
    {
      "identifier": "lightValue",
      "functionType": "u",
      "name": "光照原始值",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 4095,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "Photoresistor ADC raw value.",
      "unit": "ADC"
    },
    {
      "identifier": "lightStatus",
      "functionType": "u",
      "name": "光照状态",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 16
        }
      },
      "accessMode": "r",
      "description": "Classified light level: low, normal, or high."
    },
    {
      "identifier": "mq135Value",
      "functionType": "u",
      "name": "空气质量原始值",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 4095,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "MQ-135 ADC raw value after voltage divider.",
      "unit": "ADC"
    },
    {
      "identifier": "airQualityPercent",
      "functionType": "u",
      "name": "通风指数",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 100,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "User-facing ventilation index from MQ-135. Higher means ventilation is more needed.",
      "unit": "%"
    },
    {
      "identifier": "airQualityStatus",
      "functionType": "u",
      "name": "空气状态",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 16
        }
      },
      "accessMode": "r",
      "description": "Classified MQ-135 status: good, warning, or poor."
    },
    {
      "identifier": "rainDetected",
      "functionType": "u",
      "name": "是否下雨",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "无雨",
          "true": "有雨"
        }
      },
      "accessMode": "r",
      "description": "Rain module wet/dry detection result."
    },
    {
      "identifier": "vibrationDetected",
      "functionType": "u",
      "name": "维护活动",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "待机",
          "true": "维护中"
        }
      },
      "accessMode": "r",
      "description": "Confirmed maintenance activity inferred from sustained SW-420 vibration pulses."
    },
    {
      "identifier": "flameDetected",
      "functionType": "u",
      "name": "火焰告警",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "正常",
          "true": "检测到火焰"
        }
      },
      "accessMode": "r",
      "description": "Flame sensor digital alarm after confirmation filtering."
    },
    {
      "identifier": "tiltDetected",
      "functionType": "u",
      "name": "倾斜告警",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "正常",
          "true": "发生倾斜"
        }
      },
      "accessMode": "r",
      "description": "SW-520D tilt alarm after confirmation filtering."
    },
    {
      "identifier": "safetyAlert",
      "functionType": "u",
      "name": "安全告警",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "正常",
          "true": "告警"
        }
      },
      "accessMode": "r",
      "description": "Combined safety alarm from flame, tilt, and poor air quality."
    },
    {
      "identifier": "maintenanceEvent",
      "functionType": "u",
      "name": "维护事件",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "未触发",
          "true": "已触发"
        }
      },
      "accessMode": "r",
      "description": "A confirmed maintenance event held for a short display window."
    },
    {
      "identifier": "lastEventType",
      "functionType": "u",
      "name": "最近事件类型",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 32
        }
      },
      "accessMode": "r",
      "description": "Latest event type: flame, tilt, vibration, air, rain, or system."
    },
    {
      "identifier": "lastEventLevel",
      "functionType": "u",
      "name": "最近事件等级",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 16
        }
      },
      "accessMode": "r",
      "description": "Latest event level: critical, warning, notice, or info."
    },
    {
      "identifier": "lastEventMessage",
      "functionType": "u",
      "name": "最近事件说明",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 128
        }
      },
      "accessMode": "r",
      "description": "Human-readable latest event message for the Qt event center."
    },
    {
      "identifier": "lastEventTime",
      "functionType": "u",
      "name": "最近事件时间",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 2147483647,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "Latest event uptime timestamp in seconds."
    },
    {
      "identifier": "eventSequence",
      "functionType": "u",
      "name": "事件序号",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 2147483647,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "Monotonic sequence number. It increases only when a new event is recorded."
    },
    {
      "identifier": "irrigationState",
      "functionType": "u",
      "name": "滴灌状态",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "关闭",
          "true": "开启"
        }
      },
      "accessMode": "r",
      "description": "SG90 simulated irrigation valve state."
    },
    {
      "identifier": "servoAngle",
      "functionType": "u",
      "name": "舵机角度",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 180,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "SG90 servo angle. 0 means closed, 90 means open in the default demo.",
      "unit": "°"
    },
    {
      "identifier": "controlMode",
      "functionType": "u",
      "name": "控制模式",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 1,
          "step": 1
        }
      },
      "accessMode": "rw",
      "description": "Irrigation control mode. 0 means auto, 1 means manual."
    },
    {
      "identifier": "manualIrrigation",
      "functionType": "u",
      "name": "手动滴灌开关",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "关闭",
          "true": "开启"
        }
      },
      "accessMode": "rw",
      "description": "Manual irrigation switch used when controlMode is manual."
    },
    {
      "identifier": "openThreshold",
      "functionType": "u",
      "name": "开启阈值",
      "dataType": {
        "type": "float",
        "specs": {
          "min": 0,
          "max": 100,
          "step": 0.1
        }
      },
      "accessMode": "rw",
      "description": "Air humidity threshold for opening irrigation in auto mode.",
      "unit": "%"
    },
    {
      "identifier": "closeThreshold",
      "functionType": "u",
      "name": "关闭阈值",
      "dataType": {
        "type": "float",
        "specs": {
          "min": 0,
          "max": 100,
          "step": 0.1
        }
      },
      "accessMode": "rw",
      "description": "Air humidity threshold for closing irrigation in auto mode.",
      "unit": "%"
    },
    {
      "identifier": "rfidEnrollMode",
      "functionType": "u",
      "name": "录卡模式",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "关闭",
          "true": "开启"
        }
      },
      "accessMode": "r",
      "description": "Whether the device is waiting for a card to enroll."
    },
    {
      "identifier": "rfidAuthorized",
      "functionType": "u",
      "name": "身份授权",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "未授权",
          "true": "已授权"
        }
      },
      "accessMode": "r",
      "description": "Whether the latest RFID card is authorized."
    },
    {
      "identifier": "authorizedCardCount",
      "functionType": "u",
      "name": "已录入人数",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 5,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "Number of authorized maintenance cards stored locally."
    },
    {
      "identifier": "currentOperatorId",
      "functionType": "u",
      "name": "当前人员",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 32
        }
      },
      "accessMode": "r",
      "description": "Current authorized operator label, such as Operator 1."
    },
    {
      "identifier": "lastAccessEvent",
      "functionType": "u",
      "name": "最近刷卡事件",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 128
        }
      },
      "accessMode": "r",
      "description": "Latest RFID or touch interaction event."
    },
    {
      "identifier": "lastCardUid",
      "functionType": "u",
      "name": "最近卡号",
      "dataType": {
        "type": "string",
        "specs": {
          "length": 32
        }
      },
      "accessMode": "r",
      "description": "Latest RFID card UID read by the RC522 module."
    },
    {
      "identifier": "authRemainingSec",
      "functionType": "u",
      "name": "授权剩余时间",
      "dataType": {
        "type": "int32",
        "specs": {
          "min": 0,
          "max": 3600,
          "step": 1
        }
      },
      "accessMode": "r",
      "description": "Remaining authorization time in seconds."
    },
    {
      "identifier": "dhtHealthy",
      "functionType": "u",
      "name": "温湿度传感器状态",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "异常",
          "true": "正常"
        }
      },
      "accessMode": "r",
      "description": "DHT11 health status after consecutive read validation."
    },
    {
      "identifier": "rainSensorHealthy",
      "functionType": "u",
      "name": "雨滴传感器状态",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "异常",
          "true": "正常"
        }
      },
      "accessMode": "r",
      "description": "Rain sensor ADC and dry-baseline health status."
    },
    {
      "identifier": "mq135Healthy",
      "functionType": "u",
      "name": "空气质量传感器状态",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "异常",
          "true": "正常"
        }
      },
      "accessMode": "r",
      "description": "MQ-135 ADC health status after consecutive read validation."
    },
    {
      "identifier": "sensorHealthy",
      "functionType": "u",
      "name": "关键传感器状态",
      "dataType": {
        "type": "bool",
        "specs": {
          "false": "异常",
          "true": "正常"
        }
      },
      "accessMode": "r",
      "description": "Combined health status of sensors used by automatic irrigation."
    }
  ],
  "services": [
    {
      "identifier": "setIrrigationMode",
      "functionType": "u",
      "name": "设置滴灌模式",
      "callType": "async",
      "description": "Cloud service for switching auto/manual irrigation control and manual irrigation state.",
      "input": [
        {
          "identifier": "mode",
          "name": "控制模式",
          "dataType": {
            "type": "enum",
            "specs": {
              "0": "auto",
              "1": "manual"
            }
          }
        },
        {
          "identifier": "manualIrrigation",
          "name": "手动滴灌开关",
          "dataType": {
            "type": "bool",
            "specs": {
              "false": "关闭",
              "true": "开启"
            }
          }
        }
      ],
      "output": [
        {
          "identifier": "result",
          "name": "执行结果",
          "dataType": {
            "type": "bool",
            "specs": {
              "false": "失败",
              "true": "成功"
            }
          }
        }
      ]
    },
    {
      "identifier": "setHumidityThreshold",
      "functionType": "u",
      "name": "设置湿度阈值",
      "callType": "async",
      "description": "Cloud service for changing irrigation open and close humidity thresholds.",
      "input": [
        {
          "identifier": "openThreshold",
          "name": "开启阈值",
          "dataType": {
            "type": "float",
            "specs": {
              "min": 0,
              "max": 100,
              "step": 0.1
            }
          },
          "unit": "%"
        },
        {
          "identifier": "closeThreshold",
          "name": "关闭阈值",
          "dataType": {
            "type": "float",
            "specs": {
              "min": 0,
              "max": 100,
              "step": 0.1
            }
          },
          "unit": "%"
        }
      ],
      "output": [
        {
          "identifier": "result",
          "name": "执行结果",
          "dataType": {
            "type": "bool",
            "specs": {
              "false": "失败",
              "true": "成功"
            }
          }
        }
      ]
    }
  ],
  "events": [
    {
      "identifier": "lightAlert",
      "functionType": "u",
      "name": "光照异常",
      "eventType": "alert",
      "description": "Reserved event for low or high light alert display.",
      "outputData": [
        {
          "identifier": "lightValue",
          "name": "光照原始值",
          "dataType": {
            "type": "int32",
            "specs": {
              "min": 0,
              "max": 4095,
              "step": 1
            }
          },
          "unit": "ADC"
        },
        {
          "identifier": "lightStatus",
          "name": "光照状态",
          "dataType": {
            "type": "string",
            "specs": {
              "length": 16
            }
          }
        }
      ]
    },
    {
      "identifier": "maintenanceAlert",
      "functionType": "u",
      "name": "维护振动事件",
      "eventType": "info",
      "description": "Reserved event for pruning, maintenance, or abnormal vibration.",
      "outputData": [
        {
          "identifier": "vibrationDetected",
          "name": "当前振动",
          "dataType": {
            "type": "bool",
            "specs": {
              "false": "无振动",
              "true": "有振动"
            }
          }
        }
      ]
    }
  ]
}
